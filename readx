#!/usr/bin/env bash
# readx — drop-in replacement for `read -e`, with custom Tab behavior

_readx_tab_handler() {
  local insert_text=" [TAB COMPLETED]"
  local before=${READLINE_LINE:0:READLINE_POINT}
  local after=${READLINE_LINE:READLINE_POINT}
  READLINE_LINE="${before}${insert_text}${after}"
  (( READLINE_POINT += ${#insert_text} ))
}

_readx_cleanup() {
  local status=$?
  bind '"\t": complete' 2>/dev/null
  trap - EXIT INT TERM
  echo "_readx_cleanup: status: $status"
  exit $status
}

readx() {
  local prompt var

  # Parse: readx -p "Prompt" var
  if [[ "$1" == "-p" ]]; then
    prompt=$2
    shift 2
  fi

  var=$1
  if [[ -z "$var" ]]; then
    echo "Usage: readx [-p prompt] variable_name" >&2
    return 2
  fi

  bind -x '"\t":_readx_tab_handler' 2>/dev/null
  trap _readx_cleanup EXIT INT TERM

  local result
  if ! read -e -p "${prompt}" result; then
    echo -e "\nAborted."
    return 1
  fi

  printf -v "$var" '%s' "$result"
}
