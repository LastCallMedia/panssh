#!/usr/bin/env bash
# readx — drop-in replacement for `read -e`, with custom tab-complete logic.

_readx_tab_handler() {
  local line="$READLINE_LINE"
  local point=$READLINE_POINT
  local before=${line:0:point}
  local after=${line:point}

  local current_word="${before##*[[:space:]]}"
  local word_start=$((point - ${#current_word}))
  local prefix="${before:0:word_start}"

  local num_words
  num_words=$(awk '{ print NF }' <<< "$before")

  local completions=()
  if (( num_words <= 1 )); then
    completions=( $(compgen -A command -- "$current_word") )
  else
    completions=( $(compgen -f -- "$current_word") )
  fi
  echo "-----> compgen exit $?"

  (( ${#completions[@]} == 0 )) && return

  # Remove duplicates.
  completions=( $(printf "%s\n" "${completions[@]}" | awk '!seen[$0]++') )

  if (( ${#completions[@]} == 1 )); then
    local match="${completions[0]}"
    local inserted="${match#$current_word}"

    if (( num_words <= 1 )); then
      # Completing a command — insert a space
      inserted+=" "
    elif [[ -d "$match" ]]; then
      # Completing a directory — insert a trailing slash
      inserted+="/"
    fi

    READLINE_LINE="${before}${inserted}${after}"
    READLINE_POINT=$((point + ${#inserted}))
    return
  fi

  # Longest common prefix
  local lcp="${completions[0]}"
  for match in "${completions[@]:1}"; do
    local i=0
    while [[ "${lcp:i:1}" == "${match:i:1}" && $i -lt ${#lcp} ]]; do
      ((i++))
    done
    lcp="${lcp:0:i}"
  done

  if [[ "$lcp" != "$current_word" ]]; then
    local inserted="${lcp#$current_word}"
    READLINE_LINE="${before}${inserted}${after}"
    READLINE_POINT=$((point + ${#inserted}))
  fi

  echo -ne "\a" >&2

  # Display matches below the prompt
  {
    echo
    printf "%s\n" "${completions[@]}" | paste -sd ' ' - | fold -s -w "$(tput cols)"
  } >&2
}


_readx_return() {
  local status=$1
  bind '"\t": complete' 2>/dev/null
  trap - EXIT INT TERM
  echo "_readx_return: status: $status"
  return $status
}

readx() {
  local prompt var

  if [[ "$1" == "-p" ]]; then
    prompt=$2
    shift 2
  fi

  var=$1
  if [[ -z "$var" ]]; then
    echo "Usage: readx [-p prompt] variable_name" >&2
    return 2
  fi

  trap '_readx_return 130' EXIT INT TERM
  bind -x '"\t":_readx_tab_handler' 2>/dev/null

  local __readx_input
  if ! read -e -r -p "${prompt}" __readx_input; then
    echo -e "\nAborted."
    _readx_return 130
  fi

  printf -v "$var" '%s' "$__readx_input"
}
